APP_NAME=AxionCH API
RUNTIME_ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql://axionch:axionch@localhost:5432/axionch
API_HOST=127.0.0.1
API_PORT=8010
TOKEN_ENCRYPTION_KEY=replace-me-with-a-random-32-byte-base64-or-long-secret
# Use a strong secret (>=32 chars) for vault encryption. Example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
VAULT_ENCRYPTION_KEY=replace-me-with-a-random-32-byte-base64-or-long-secret
API_KEY=
API_KEY_HASH_SALT=replace-me-with-a-random-salt
ENFORCE_API_AUTH=true
ALLOW_BOOTSTRAP_WITHOUT_API_KEY=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://10.0.2.2:3000
CORS_ALLOW_CREDENTIALS=true
DRY_RUN_HISTORY_MAX_ITEMS=200
PUBLISH_RETRY_MAX_ATTEMPTS=3
PUBLISH_RETRY_BACKOFF_SECONDS=1.0
PUBLISH_QUEUE_MAX_ATTEMPTS=3
PUBLISH_QUEUE_BASE_BACKOFF_SECONDS=2.0
PLATFORM_SECRETS_ENV_FALLBACK=true
FFMPEG_BINARY=ffmpeg
FFMPEG_TIMEOUT_SECONDS=240
MEDIA_OUTPUT_DIR=media_outputs
IMAGE_OUTPUT_DIR=media_outputs/images
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=60.0
MEDIA_MAX_DOWNLOAD_BYTES=50000000
MEDIA_ALLOW_HTTP_SOURCE_URLS=false
MEDIA_ALLOWED_SOURCE_DOMAINS=
MEDIA_BLOCKED_SOURCE_HOSTS=localhost,127.0.0.1,0.0.0.0,169.254.169.254,metadata.google.internal
MEDIA_BLOCK_PRIVATE_NETWORKS=true
MEDIA_ALLOWED_VIDEO_MIME_PREFIXES=video/
MEDIA_ALLOWED_IMAGE_MIME_PREFIXES=image/
OAUTH_STATE_TTL_SECONDS=600
OAUTH_EXCHANGE_TIMEOUT_SECONDS=20.0
OAUTH_REFRESH_ENABLED=true
OAUTH_REFRESH_INTERVAL_SECONDS=60.0
OAUTH_REFRESH_AHEAD_SECONDS=300
OAUTH_REFRESH_FAILURE_BACKOFF_SECONDS=300.0

# X (Twitter)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_REDIRECT_URI=
X_OAUTH_TOKEN_URL=https://api.twitter.com/2/oauth2/token

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_REDIRECT_URI=
LINKEDIN_OAUTH_TOKEN_URL=https://www.linkedin.com/oauth/v2/accessToken

# Instagram / Meta
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_OAUTH_TOKEN_URL=https://graph.facebook.com/v20.0/oauth/access_token
INSTAGRAM_OAUTH_REFRESH_URL=https://graph.instagram.com/refresh_access_token
